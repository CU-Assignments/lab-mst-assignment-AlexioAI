public class EncodeThreeStrings {
    public static String[] process(String s1, String s2, String s3) {
        String[] p1 = split(s1), p2 = split(s2), p3 = split(s3);
        String out1 = p1[0] + p2[1] + p3[2];
        String out2 = p1[1] + p2[2] + p3[0];
        String out3 = p1[2] + p2[0] + p3[1];
        out3 = toggleCase(out3);
        return new String[] { out1, out2, out3 };
    }

    private static String[] split(String s) {
        int len = s.length(), part = len / 3, rem = len % 3;
        int[] sizes = {part, part, part};
        if (rem == 1) sizes[1]++;
        else if (rem == 2) { sizes[0]++; sizes[2]++; }
        int i = 0;
        String front = s.substring(i, i += sizes[0]);
        String mid = s.substring(i, i += sizes[1]);
        String end = s.substring(i);
        return new String[]{front, mid, end};
    }

    private static String toggleCase(String s) {
        StringBuilder sb = new StringBuilder();
        for (char c : s.toCharArray())
            sb.append(Character.isUpperCase(c) ? Character.toLowerCase(c) : Character.toUpperCase(c));
        return sb.toString();
    }

    public static void main(String[] args) {
        String[] result = process("John", "Johny", "Janardhan");
        for (String s : result) System.out.println(s);
    }
}
// Output:
// jhhan
// ohnyJan
// NJOARD


