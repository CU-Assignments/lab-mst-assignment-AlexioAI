public class MathOperations {
    int add(int a, int b) { return a + b; }
    double add(double a, double b) { return a + b; }
    int add(int a, int b, int c) { return a + b + c; }

    public static void main(String[] args) {
        MathOperations mo = new MathOperations();
        System.out.println(mo.add(5, 10));
        System.out.println(mo.add(5.5, 10.3));
        System.out.println(mo.add(1, 2, 3));
    }
}
// Output:
// 15
// 15.8
// 6


// QUESTION 5
public class AlphabetTransform {
    public static String transform(String input) {
        StringBuilder sb = new StringBuilder();
        for (int i = 0; i < input.length(); ) {
            char c = input.charAt(i);
            if (Character.isLetter(c)) {
                if (i + 1 < input.length() && Character.isLetter(input.charAt(i + 1))) {
                    int sum = charVal(c) + charVal(input.charAt(i + 1));
                    sb.append(Character.toLowerCase(c));
                    sb.append(sum % 26 == 0 ? "0" : String.valueOf((char)((sum % 26 - 1) + 'a')));
                    sb.append(Character.toLowerCase(input.charAt(i + 1)));
                    i += 2;
                } else {
                    sb.append(Character.toLowerCase(c));
                    i++;
                }
            } else {
                sb.append(c);
                i++;
            }
        }
        return sb.toString();
    }

    private static int charVal(char c) {
        return Character.toLowerCase(c) - 'a' + 1;
    }

    public static void main(String[] args) {
        System.out.println(transform("ay"));
        System.out.println(transform("ac"));
        System.out.println(transform("12"));
        System.out.println(transform("1a"));
        System.out.println(transform("ac 12a"));
    }
}
// Output:
// a0y
// adc
// 12
// 1a
// adc 12a


